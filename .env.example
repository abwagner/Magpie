# Magpie environment configuration — copy to `.env` and fill in.
#
#   cp .env.example .env
#
# `.env` is gitignored; never commit real credentials. Every value below is a
# placeholder. Leave a variable blank to disable the feature that uses it —
# the framework runs in paper mode against local files with no vendor keys.
#
# Legend:  [required]    needed for the core server to start / paper-trade
#          [optional]    only needed for the feature noted in the comment
#          (default: …)  the value used when the variable is unset

# ── Core ──────────────────────────────────────────────────────────
APP_ENV=dev                    # [required] dev | prod
TRADING_MODE=paper             # [required] paper | live  (live also needs broker creds)
VITE_APP_TIMEZONE=America/New_York   # [optional] UI display timezone (default: America/New_York)

# ── Market data + broker credentials (used by the API server) ─────
# MarketData.app token — equity options live + historical.
#   Get one at https://www.marketdata.app/ (Trader plan recommended).
MD_TOKEN=                      # [optional] equity options market data

# Charles Schwab developer app — equity positions/options (optional).
#   Register an app at https://developer.schwab.com/ to obtain these.
SCHWAB_APP_KEY=                # [optional] Schwab OAuth client id
SCHWAB_APP_SECRET=             # [optional] Schwab OAuth client secret
SCHWAB_REFRESH_TOKEN=          # [optional] Schwab OAuth refresh token

# Interactive Brokers Gateway / TWS — futures, futures options, execution.
#   Run IB Gateway locally; defaults target a paper gateway on localhost.
IBKR_HOST=127.0.0.1            # [optional] IB Gateway host (default: 127.0.0.1)
IBKR_PORT=4002                 # [optional] 4002 = paper gateway, 4001 = live (default: 4002)

# ── Data backend ──────────────────────────────────────────────────
# DATA_URI is the canonical data root (chains, signals, macro, futures, fills,
# results, …) read by server/orchestrator/storage.ts. Two modes:
#   - Local filesystem (simplest, no extra setup):  file://./data
#   - S3 / MinIO object store (for shared/cloud deployments): s3://<bucket>
DATA_URI=file://./data         # [required] (default mode is local files)

# Only needed when DATA_URI is s3://. Point at AWS S3 or any S3-compatible
# service (e.g. self-hosted MinIO). Endpoint is also set in config/storage.json.
S3_ENDPOINT_URL=               # [optional] e.g. https://s3.amazonaws.com or your MinIO URL
S3_REGION=us-east-1            # [optional] (default: us-east-1)
S3_ACCESS_KEY=                 # [optional] S3/MinIO access key
S3_SECRET_KEY=                 # [optional] S3/MinIO secret key

# portfolio.duckdb is a file-based DuckDB catalog that stays local even when
# DATA_URI is s3://. Override the path for a server deployment if desired.
# CATALOG_DB_PATH=./data/portfolio.duckdb   # [optional] (default: ./data/portfolio.duckdb)

# Legacy AWS_* vars for tooling that uses the default AWS credential chain
# (boto3, aws cli). Set to the same values as S3_ACCESS_KEY/S3_SECRET_KEY.
AWS_ACCESS_KEY_ID=             # [optional] mirror of S3_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=         # [optional] mirror of S3_SECRET_KEY
AWS_DEFAULT_REGION=us-east-1   # [optional] (default: us-east-1)

# ── Write-dispatch ────────────────────────────────────────────────
# Data writes go through the QF server's dispatch API. Issue a per-actor token
# once via `npm run issue-write-token --` and paste the plaintext here; the CLI
# ingest scripts read this variable.
WRITE_JOB_TOKEN=               # [optional] required only for server-mediated writes
# WRITE_JOB_TOKEN_PATH=./data/secrets/write-job-tokens.json   # [optional] token store path
# WRITE_JOB_API_BASE=http://localhost:3001                    # [optional] (default: http://localhost:3001)

# ── External data vendors (each optional; enables its ingest source) ──
DATABENTO_API_KEY=             # [optional] Databento — https://databento.com/
AISSTREAM_API_KEY=             # [optional] aisstream.io vessel AIS feed
FMP_API_KEY=                   # [optional] Financial Modeling Prep — https://financialmodelingprep.com/
EIA_API_KEY=                   # [optional] US EIA Open Data — https://www.eia.gov/opendata/
FRED_API_KEY=                  # [optional] FRED — https://fred.stlouisfed.org/docs/api/api_key.html
CDSE_CLIENT_ID=                # [optional] Copernicus Data Space Ecosystem (satellite)
CDSE_CLIENT_SECRET=            # [optional] Copernicus Data Space Ecosystem (satellite)

# Local parquet store for auxiliary data-signal pipelines (eia/, fred/, cftc/, …).
DATA_DIR=./trading-data        # [optional] (default: ./trading-data)
