{
  "name": "magpie",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gate-evaluator-cli": "dist/bin/gate-evaluator-cli.js"
  },
  "scripts": {
    "start": "concurrently -n server,vite -c blue,green \"npm run server\" \"npm run dev\"",
    "server": "tsx server/index.ts",
    "dev": "vite",
    "build": "vite build",
    "build:cli": "tsc --noEmit false --outDir dist --declaration false --sourceMap false",
    "build:wasm": "wasm-pack build core/qf-optimizer --target web --out-dir ../../src/lib/wasm/qf_optimizer --no-default-features --features wasm",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --ignore-pattern node_modules --ignore-pattern dist",
    "check": "npm run typecheck && npm run lint && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "schwab-auth": "node scripts/schwab-auth.js",
    "ingest": "tsx scripts/ingest.ts",
    "fmp-backfill": "tsx scripts/fmp-backfill.ts",
    "issue-write-token": "tsx scripts/issue-write-token.ts",
    "collect": "node scripts/collect-history.js",
    "collect:bulk": "tsx scripts/collect-bulk.ts",
    "databento:pull": "tsx scripts/databento-pull.ts",
    "scheduler": "tsx scripts/scheduler.ts",
    "backup-observability": "tsx scripts/backup-observability.ts",
    "snapshot": "node scripts/ibkr-snapshot.js",
    "observability:up": "docker-compose --profile observability up -d",
    "observability:down": "docker-compose --profile observability down",
    "observability:logs": "docker-compose --profile observability logs -f"
  },
  "dependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@stoqey/ib": "^1.5.3",
    "croner": "^10.0.1",
    "duckdb": "^1.2.2",
    "lightweight-charts": "^5.2.0",
    "nats": "^2.29.3",
    "plotly.js-basic-dist-min": "^3.6.0",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ulid": "^3.0.2",
    "unzipper": "^0.12.3",
    "ws": "^8.21.0",
    "yahoo-finance2": "^3.14.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unzipper": "^0.10.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "tar": "^7.5.16",
    "@tootallnate/once": "^3.0.1",
    "brace-expansion": "^5.0.6",
    "shell-quote": "1.8.4",
    "esbuild": "^0.28.1"
  }
}
